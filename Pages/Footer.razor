@* ==========================================================================
   Footer.razor — Site footer with logo and social links
   ========================================================================== *@

<footer class="site-footer">
    <div class="container site-footer__inner">
        <div class="site-footer__brand">
            <span class="navbar__logo-mark"></span>
            <span class="navbar__logo-text">Doped Games</span>
        </div>

        <p class="site-footer__copy">&copy; @DateTime.Now.Year Doped Games. All rights reserved.</p>

        <div class="site-footer__social">
            @foreach (var social in SocialLinks)
            {
                <a href="@social.Href" class="site-footer__social-link" aria-label="@social.Label" target="_blank" rel="noopener noreferrer">
                    @((MarkupString)social.IconSvg)
                </a>
            }
        </div>
    </div>
</footer>

@code {
    private record Social(string Label, string Href, string IconSvg);

    private readonly List<Social> SocialLinks = new()
    {
        new("Discord", "#", "<svg viewBox='0 0 24 24' fill='currentColor'><path d='M20 5.5a17 17 0 00-4.3-1.3l-.2.4a14 14 0 00-7 0l-.2-.4A17 17 0 004 5.5C2 9 1.4 12.4 1.6 15.8a17 17 0 005.2 2.6l.8-1.4a11 11 0 01-1.7-.8l.4-.3a12 12 0 0011.4 0l.4.3c-.5.3-1.1.6-1.7.8l.8 1.4a17 17 0 005.2-2.6C22.6 12.1 21.7 8.8 20 5.5zM9 14c-.8 0-1.5-.8-1.5-1.7S8.1 10.6 9 10.6s1.6.8 1.5 1.7c0 .9-.7 1.7-1.5 1.7zm6 0c-.8 0-1.5-.8-1.5-1.7s.6-1.7 1.5-1.7 1.6.8 1.5 1.7c0 .9-.7 1.7-1.5 1.7z'/></svg>"),
        new("Twitter", "#", "<svg viewBox='0 0 24 24' fill='currentColor'><path d='M23 5.1c-.8.4-1.7.7-2.6.8a4.6 4.6 0 002-2.5c-.9.5-1.8.9-2.9 1.1a4.5 4.5 0 00-7.7 4.1A12.9 12.9 0 012 4.8a4.5 4.5 0 001.4 6 4.4 4.4 0 01-2-.6v.1a4.5 4.5 0 003.6 4.4c-.4.1-.9.2-1.4.1.4 1.3 1.7 2.3 3.2 2.3A9 9 0 012 19a12.8 12.8 0 007 2c8.3 0 12.9-7 12.9-13v-.6c.9-.6 1.6-1.4 2.1-2.3z'/></svg>"),
