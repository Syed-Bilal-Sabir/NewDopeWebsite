@* ==========================================================================
   PlayGame.razor — Unity WebGL game page
   Route: /play-game

   Expects your Unity 2022+ WebGL build to be placed at:
     wwwroot/
       game/
         Build/
           game.loader.js        ← rename your actual .loader.js to this
           game.data.gz          ← (or .data / .data.br depending on compression)
           game.framework.js.gz
           game.wasm.gz
         index.html              ← Unity's generated index (not used directly,
                                    we load via JS below instead)

   If your build files have different names, update the loaderUrl,
   dataUrl, frameworkUrl and codeUrl variables in the @code block below.
   ========================================================================== *@

@page "/play-game"
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="game-page">
    <VideoBackground />

    <div class="game-page__inner">

        {{!-- Header row --}}
        <div class="game-page__header">
            <a href="/" class="game-page__back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 5l-7 7 7 7"/>
                </svg>
                Back to site
            </a>

            <div class="game-page__title-block">
                <span class="game-page__label">Doped Games</span>
                <h1 class="game-page__title">@GameTitle</h1>
            </div>

            <button class="btn btn-outline game-page__fullscreen-btn"
                    @onclick="RequestFullscreen"
                    title="Toggle fullscreen">
                <svg class="game-page__fs-icon" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.8">
                    <path d="M8 3H5a2 2 0 00-2 2v3M21 8V5a2 2 0 00-2-2h-3M16 21h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/>
                </svg>
                Fullscreen
            </button>
        </div>

        {{!-- Canvas wrapper --}}
        <div class="game-page__canvas-wrap" id="unityCanvasWrap">
            @if (_loading)
            {
                <div class="game-page__loader">
                    <div class="game-page__loader-bar">
                        <div class="game-page__loader-fill"
                             style="width: @(_progress.ToString("F0"))%"></div>
                    </div>
                    <p class="game-page__loader-text">
                        LOADING @_progress.ToString("F0")%
                    </p>
                </div>
            }

            @if (_error is not null)
            {
                <div class="game-page__error">
                    <p>⚠ Failed to load the game</p>
                    <p class="game-page__error-detail">@_error</p>
                    <button class="btn btn-primary" @onclick="LoadGame">Retry</button>
                </div>
            }

            <canvas id="unityCanvas" class="game-page__canvas"></canvas>
        </div>

        {{!-- Footer row --}}
        <div class="game-page__footer">
            <p class="game-page__description">@GameDescription</p>
            <div class="game-page__badges">
                @foreach (var tag in GameTags)
                {
                    <span class="game-page__badge">@tag</span>
                }
            </div>
        </div>

    </div>
</div>

@code {
    // ── Customise these to match your game ──────────────────────────────────
    private const string GameTitle       = "PAWS & REWARDS";
    private const string GameDescription = "A slot machine game where players can win big prizes.";
    private static readonly string[] GameTags = { "Action", "Platformer", "WebGL" };

    // ── Unity build file paths (relative to wwwroot) ─────────────────────
    // Rename your actual Unity-generated files to match these, or change
    // these strings to match whatever Unity named them.
    private const string LoaderUrl    = "games/Build/game.loader.js";
    private const string DataUrl      = "games/Build/game.data";
    private const string FrameworkUrl = "games/Build/game.framework.js";
    private const string CodeUrl      = "games/Build/game.wasm";
    // ── End customisation ────────────────────────────────────────────────────

    private bool   _loading  = false;
    private double _progress = 0;
    private string? _error   = null;

    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadGame();
        }
    }

    private async Task LoadGame()
    {
        _error    = null;
        _loading  = true;
        _progress = 0;
        StateHasChanged();

        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/unity-loader.js");

            var selfRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("loadUnity",
                "unityCanvas", LoaderUrl, DataUrl, FrameworkUrl, CodeUrl, selfRef);
        }
        catch (Exception ex)
        {
            _error   = ex.Message;
            _loading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnProgress(double progress)
    {
        _progress = progress * 100;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnLoaded()
    {
        _loading = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnError(string message)
    {
        _error   = message;
        _loading = false;
        StateHasChanged();
    }

    private async Task RequestFullscreen()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("goFullscreen", "unityCanvasWrap");
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unloadUnity");
                await _module.DisposeAsync();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }
}
