@page "/play-game/{GameId}"
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="game-page">
    <div class="game-page__inner">

        @* Header row *@
        <div class="game-page__header">
            <a href="/" class="game-page__back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 5l-7 7 7 7" />
                </svg>
                Back to site
            </a>

            <div class="game-page__title-block">
                <span class="game-page__label">GLITCH STUDIO</span>
                <h1 class="game-page__title">@CurrentGame?.Title</h1>
            </div>

            <button class="btn btn-outline game-page__fullscreen-btn"
                    @onclick="RequestFullscreen"
                    title="Toggle fullscreen">
                <svg class="game-page__fs-icon" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.8">
                    <path d="M8 3H5a2 2 0 00-2 2v3M21 8V5a2 2 0 00-2-2h-3M16 21h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3" />
                </svg>
                Fullscreen
            </button>
        </div>

        @* Canvas wrapper *@
        <div class="game-page__canvas-wrap" id="unityCanvasWrap">
            @if (_loading)
            {
                <div class="game-page__loader">
                    <div class="game-page__loader-bar">
                        <div class="game-page__loader-fill"
                             style="width: @(_progress.ToString("F0"))%"></div>
                    </div>
                    <p class="game-page__loader-text">
                        LOADING @_progress.ToString("F0")%
                    </p>
                </div>
            }

            @if (_error is not null)
            {
                <div class="game-page__error">
                    <p>⚠ Failed to load the game</p>
                    <p class="game-page__error-detail">@_error</p>
                    <button class="btn btn-primary" @onclick="LoadGame">Retry</button>
                </div>
            }

            @if (CurrentGame is null && _error is null)
            {
                <div class="game-page__error">
                    <p>⚠ Game not found</p>
                    <p class="game-page__error-detail">No game exists with id "@GameId"</p>
                    <a href="/" class="btn btn-primary">Go Home</a>
                </div>
            }

            <canvas id="unityCanvas" class="game-page__canvas"></canvas>
        </div>

        @* Footer row *@
        <div class="game-page__footer">
            <p class="game-page__description">@CurrentGame?.Description</p>
            <div class="game-page__badges">
                @foreach (var tag in CurrentGame?.Tags ?? Array.Empty<string>())
                {
                    <span class="game-page__badge">@tag</span>
                }
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter] public string GameId { get; set; } = "";

    // ── Add all your games here ──────────────────────────────────────────
    private static readonly Dictionary<string, GameInfo> Games = new()
    {
        ["tyche"] = new GameInfo(
        Title: "TYCHE",
        Description: "Experience the action-packed world of Tyche.",
        Tags: new[] { "Action", "Strategy", "WebGL" },
        BuildPath: "games/Tyche/Build/Tyche"
    ),
        ["beach"] = new GameInfo(
        Title: "BEACH",
        Description: "Solve puzzles in a beautiful beach setting.",
        Tags: new[] { "Puzzle", "Strategy", "WebGL" },
        BuildPath: "games/Beach/Build/Beach"
    ),
        ["norse"] = new GameInfo(
        Title: "NORSE",
        Description: "Battle through Norse mythology in this epic shooter.",
        Tags: new[] { "Shooter", "Strategy", "WebGL" },
        BuildPath: "games/Norse/Build/Norse"
    ),
        ["soccer"] = new GameInfo(
        Title: "SOCCER",
        Description: "Play casual soccer with strategic gameplay.",
        Tags: new[] { "Casual", "Strategy", "WebGL" },
        BuildPath: "games/Soccer/Build/Soccer"
    ),
        ["pet"] = new GameInfo(
        Title: "PET",
        Description: "Sort and match in this fun pet-themed game.",
        Tags: new[] { "Sorting", "Strategy", "WebGL" },
        BuildPath: "games/Pet/Build/Pet"
    ),
        ["wild"] = new GameInfo(
        Title: "WILD WEST",
        Description: "Experience the thrill of the Wild West in this exciting game.",
        Tags: new[] { "Adventure", "Strategy", "WebGL" },
        BuildPath: "games/Wild/Build/Wild"
    ),
    };
    // ── End game config ──────────────────────────────────────────────────

    private GameInfo? CurrentGame => Games.TryGetValue(GameId?.ToLower() ?? "", out var g) ? g : null;

    private bool _loading = false;
    private double _progress = 0;
    private string? _error = null;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CurrentGame is not null)
            await LoadGame();
    }

    private async Task LoadGame()
    {
        if (CurrentGame is null) return;

        _error = null;
        _loading = true;
        _progress = 0;
        StateHasChanged();

        var loaderUrl = $"{CurrentGame.BuildPath}.loader.js";
        var dataUrl = $"{CurrentGame.BuildPath}.data";
        var frameworkUrl = $"{CurrentGame.BuildPath}.framework.js";
        var codeUrl = $"{CurrentGame.BuildPath}.wasm";

        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/unity-loader.js");

            var selfRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("loadUnity",
                "unityCanvas", loaderUrl, dataUrl, frameworkUrl, codeUrl, selfRef);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnProgress(double progress)
    {
        _progress = progress * 100;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnLoaded()
    {
        _loading = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnError(string message)
    {
        _error = message;
        _loading = false;
        StateHasChanged();
    }

    private async Task RequestFullscreen()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("goFullscreen", "unityCanvasWrap");
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unloadUnity");
                await _module.DisposeAsync();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }

    private record GameInfo(string Title, string Description, string[] Tags, string BuildPath);
}