@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="video-bg-container">
    <div class="video-bg-overlay"></div>

    <video @ref="videoElement"
           class="video-bg-element"
           autoplay
           muted="muted"
           loop
           playsinline
           >
        <source src="videos/MainThemebg.mp4" type="video/mp4" />
        Your browser does not support the video tag.
    </video>
</div>

@code {
    private ElementReference videoElement;
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize the scroll tracking script
            module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/videoScroll.js");
            await module.InvokeVoidAsync("initVideoScroll", videoElement);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.InvokeVoidAsync("destroyVideoScroll");
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}